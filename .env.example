# Local environment variables. Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# URL of the SpecBuild backend (Kotlin/Spring Boot service).
# See FRONTEND_INTEGRATION.md for the full API contract.
# Local dev: http://localhost:8080 (default per spec)
# Production: https://<your-render-app>.onrender.com
VITE_API_URL=http://localhost:8080

# Where bug reports and contact-form submissions get delivered.
# Used as the mailto: fallback address if VITE_FORMSPREE_ID is empty.
VITE_CONTACT_EMAIL=muhammadkonecom@gmail.com

# Formspree form ID for the contact / bug-report form (optional).
# Get one at https://formspree.io (free, ~2 min). Set this in your
# deploy platform's env-var UI (e.g. Render dashboard) rather than
# committing it here. Leave empty to fall back to a mailto: link.
VITE_FORMSPREE_ID=

